{
  "manifest_version": 3,
  "name": "Chapter Collector",
  "version": "3.0",
  "description": "Collect chapters from WebNovel and Royal Road for personal analysis",
  "permissions": ["storage", "scripting", "activeTab", "downloads"],
  "host_permissions": [
    "https://www.webnovel.com/*",
    "https://www.royalroad.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.webnovel.com/book/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.royalroad.com/fiction/*/chapter/*"],
      "js": ["content-rr.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  }
}
